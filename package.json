{
  "name": "vibe-accounting-malaysia",
  "private": true,
  "version": "0.1.0",
  "description": "Vibe Accounting Malaysia — NestJS API + Next.js front end",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspaces --if-present run build",
    "lint": "npm --workspaces --if-present run lint",
    "test": "npm --workspaces --if-present run test"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
