# Public entrypoint exposed to the host
PUBLIC_PORT=8080

# Secrets (override in production!)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
WEB_ORIGIN=http://localhost:8080

# Container-internal URLs (used by api to reach postgres/redis)
# These stay on the Docker bridge network and are NOT exposed to the host.
DATABASE_URL=postgresql://vibe:vibe@postgres:5432/vibe
REDIS_URL=redis://redis:6379
